NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
RESEND_API_KEY=
# Production should use noreply@tornygolf.no once the Resend domain is verified.
RESEND_FROM_EMAIL=noreply@tornygolf.no

# Product-update digest (issue #202)
# CRON_SECRET: Vercel sends this as Bearer-token on /api/cron/* requests.
#   Sett til en lang random streng. Vercel-dashboardet eksponerer denne
#   automatisk når cron-jobben kjøres.
CRON_SECRET=
# PRODUCT_UPDATE_UNSUB_SECRET: HMAC-nøkkel for å signere unsub-tokens i
#   månedsbrev-mail. Bruk en lang random streng — rotering invaliderer
#   alle eksisterende mail-unsub-lenker.
PRODUCT_UPDATE_UNSUB_SECRET=

# Selv-registrering uten invitasjon (issue #166)
# NEXT_PUBLIC_ALLOW_SELF_REGISTRATION: når 'true' kan nye besøkende få
#   OTP-kode på /login uten å være forhåndsinvitert. Beskyttet av
#   honeypot + per-email/per-IP rate-limit. Default 'false' — slå på i
#   Vercel prod manuelt etter preview-testing. Kill-switch ved abuse:
#   sett tilbake til 'false' og redeploy.
NEXT_PUBLIC_ALLOW_SELF_REGISTRATION=false

# ANTHROPIC_API_KEY — nøkkel for AI-rundereferatet («Pressetribunen», #1008).
# Uten nøkkel hopper appen stille over referat-genereringen — resten av
# avslutt-flyten er upåvirket. Settes i Vercel av eieren når featuren skal på.
ANTHROPIC_API_KEY=
