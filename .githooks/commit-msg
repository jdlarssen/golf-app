#!/usr/bin/env bash
# Håndhever versjonering-disiplinen beskrevet i CLAUDE.md "Versjonering / CHANGELOG".
#
# Slår ut på conventional-commit-prefiksene som signaliserer bruker-synlig endring:
#   feat(...)   → krever MINOR-bump
#   fix(...)    → krever PATCH-bump
#   perf(...)   → krever PATCH-bump
#
# Skip-typer (regelen ignorerer disse): docs, refactor, test, chore, style, ci, build.
# Bruk dem hvis commiten ikke endrer hva brukeren kan se eller gjøre.

set -e

msg_file="$1"
[ -z "$msg_file" ] && exit 0

msg="$(head -n 1 "$msg_file")"

# Ignorer merge-, revert-, fixup-, squash-commits
case "$msg" in
  Merge\ *|Revert\ *|"fixup! "*|"squash! "*) exit 0 ;;
esac

# Bare håndhev for bruker-synlige commit-typer
if ! printf '%s' "$msg" | grep -qE '^(feat|fix|perf)(\([^)]+\))?!?: '; then
  exit 0
fi

staged="$(git diff --cached --name-only)"

fail=0
errors=""

if ! printf '%s\n' "$staged" | grep -qx 'package.json'; then
  fail=1
  errors="${errors}  • package.json er ikke staget — version-feltet må bumpes\n"
elif ! git diff --cached package.json | grep -q '^\+  "version":'; then
  fail=1
  errors="${errors}  • package.json er staget, men version-feltet er ikke endret\n"
fi

if ! printf '%s\n' "$staged" | grep -qx 'CHANGELOG.md'; then
  fail=1
  errors="${errors}  • CHANGELOG.md er ikke staget — legg til entry for denne releasen\n"
fi

if [ "$fail" -eq 1 ]; then
  prefix="$(printf '%s' "$msg" | grep -oE '^(feat|fix|perf)')"
  case "$prefix" in
    feat) bump="npm version minor --no-git-tag-version" ;;
    fix|perf) bump="npm version patch --no-git-tag-version" ;;
  esac

  printf '\n✗ Commit blokkert: versjonering-disiplinen mangler\n\n' >&2
  printf '%b' "$errors" >&2
  printf '\nReglene står i CLAUDE.md → "Versjonering / CHANGELOG".\n\n' >&2
  printf 'For å fortsette:\n' >&2
  printf '  1. %s\n' "$bump" >&2
  printf '  2. Legg til entry i CHANGELOG.md (## [X.Y.Z] - %s)\n' "$(date +%Y-%m-%d)" >&2
  printf '  3. git add package.json package-lock.json CHANGELOG.md\n' >&2
  printf '  4. git commit (på nytt med samme melding)\n\n' >&2
  printf 'Hvis commiten IKKE endrer bruker-synlig oppførsel: bytt prefix til\n' >&2
  printf '  docs(...)    dokumentasjon\n' >&2
  printf '  refactor(...) intern restrukturering\n' >&2
  printf '  test(...)    test-endringer\n' >&2
  printf '  chore(...)   tooling/config\n\n' >&2
  exit 1
fi

exit 0
