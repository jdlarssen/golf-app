#!/usr/bin/env bash
# Håndhever versjonering-disiplinen beskrevet i CLAUDE.md "Versjonering / CHANGELOG".
#
# Slår ut på conventional-commit-prefiksene som signaliserer bruker-synlig endring:
#   feat(...)   → krever MINOR-bump
#   fix(...)    → krever PATCH-bump
#   perf(...)   → krever PATCH-bump
#
# Skip-typer (regelen ignorerer disse): docs, refactor, test, chore, style, ci, build.
# Bruk dem hvis commiten ikke endrer hva brukeren kan se eller gjøre.

set -e

msg_file="$1"
[ -z "$msg_file" ] && exit 0

msg="$(head -n 1 "$msg_file")"

# Ignorer merge-, revert-, fixup-, squash-commits
case "$msg" in
  Merge\ *|Revert\ *|"fixup! "*|"squash! "*) exit 0 ;;
esac

# ─────────────────────────────────────────────────────────────────────
# Issue-referanse (CLAUDE.md → "Branch + PR-flyt": «alle med Refs #N i body»).
# Alt backlog-arbeid spores i GitHub Issues, så feat/fix/perf/refactor MÅ peke
# på et issue i commit-body-en. Escape for ekte issue-løse endringer: skriv
# [no-issue] i body-en.
# ─────────────────────────────────────────────────────────────────────
if printf '%s' "$msg" | grep -qE '^(feat|fix|perf|refactor)(\([^)]+\))?!?: '; then
  body="$(cat "$msg_file")"
  if ! printf '%s' "$body" | grep -qE '(Refs|Closes|Fixes|Resolves) #[0-9]+' \
     && ! printf '%s' "$body" | grep -qF '[no-issue]'; then
    printf '\n✗ Commit blokkert: mangler issue-referanse i body.\n\n' >&2
    printf '  Alt backlog-arbeid spores i GitHub Issues. Legg til en body-linje:\n' >&2
    printf '    Refs #123      (eller Closes #123 på siste commit i en PR)\n\n' >&2
    printf '  Reglene står i CLAUDE.md → "Branch + PR-flyt".\n' >&2
    printf '  Ekte issue-løs endring (sjelden)? Skriv [no-issue] i body-en.\n\n' >&2
    exit 1
  fi
fi

# Bare håndhev for bruker-synlige commit-typer
if ! printf '%s' "$msg" | grep -qE '^(feat|fix|perf)(\([^)]+\))?!?: '; then
  exit 0
fi

staged="$(git diff --cached --name-only)"

fail=0
errors=""

if ! printf '%s\n' "$staged" | grep -qx 'package.json'; then
  fail=1
  errors="${errors}  • package.json er ikke staget — version-feltet må bumpes\n"
elif ! git diff --cached package.json | grep -q '^\+  "version":'; then
  fail=1
  errors="${errors}  • package.json er staget, men version-feltet er ikke endret\n"
fi

if ! printf '%s\n' "$staged" | grep -qx 'CHANGELOG.md'; then
  fail=1
  errors="${errors}  • CHANGELOG.md er ikke staget — legg til entry for denne releasen\n"
fi

if [ "$fail" -eq 1 ]; then
  prefix="$(printf '%s' "$msg" | grep -oE '^(feat|fix|perf)')"
  case "$prefix" in
    feat) bump="npm version minor --no-git-tag-version" ;;
    fix|perf) bump="npm version patch --no-git-tag-version" ;;
  esac

  printf '\n✗ Commit blokkert: versjonering-disiplinen mangler\n\n' >&2
  printf '%b' "$errors" >&2
  printf '\nReglene står i CLAUDE.md → "Versjonering / CHANGELOG".\n' >&2
  printf 'CHANGELOG-format: docs/changelog-conventions.md (les FØR ny oppføring).\n\n' >&2
  printf 'For å fortsette:\n' >&2
  printf '  1. %s\n' "$bump" >&2
  printf '  2. Legg til entry i CHANGELOG.md (## [X.Y.Z] - %s)\n' "$(date +%Y-%m-%d)" >&2
  printf '  3. git add package.json package-lock.json CHANGELOG.md\n' >&2
  printf '  4. git commit (på nytt med samme melding)\n\n' >&2
  printf 'Hvis commiten IKKE endrer bruker-synlig oppførsel: bytt prefix til\n' >&2
  printf '  docs(...)    dokumentasjon\n' >&2
  printf '  refactor(...) intern restrukturering\n' >&2
  printf '  test(...)    test-endringer\n' >&2
  printf '  chore(...)   tooling/config\n\n' >&2
  exit 1
fi

# ─────────────────────────────────────────────────────────────────────
# Bump-TYPE-vakt (CLAUDE.md → "Versjonering / CHANGELOG"): H1 over sjekker at
# version-feltet ENDRET seg; her sjekker vi at det endret seg til RIKTIG type.
#   feat        → MINOR eller MAJOR (blokker hvis kun PATCH)
#   fix | perf  → PATCH (blokker MINOR; MAJOR kun ved breaking «!» / BREAKING CHANGE)
# Legit major/breaking-bump slipper gjennom, så ~null falske treff.
# ─────────────────────────────────────────────────────────────────────
old="$(git diff --cached package.json | grep -E '^-  "version":' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)"
new="$(git diff --cached package.json | grep -E '^\+  "version":' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)"

if [ -n "$old" ] && [ -n "$new" ]; then
  IFS=. read -r oM om op <<EOF
$old
EOF
  IFS=. read -r nM nm np <<EOF
$new
EOF
  prefix="$(printf '%s' "$msg" | grep -oE '^(feat|fix|perf)')"
  breaking=0
  if printf '%s' "$msg" | grep -qE '^(feat|fix|perf)(\([^)]+\))?!:'; then breaking=1; fi
  if cat "$msg_file" | grep -qE 'BREAKING CHANGE'; then breaking=1; fi

  if [ "$nM" -gt "$oM" ]; then kind=major
  elif [ "$nM" -eq "$oM" ] && [ "$nm" -gt "$om" ]; then kind=minor
  elif [ "$nM" -eq "$oM" ] && [ "$nm" -eq "$om" ] && [ "$np" -gt "$op" ]; then kind=patch
  else kind=unknown; fi

  typefail=""
  case "$prefix" in
    feat)
      [ "$kind" = patch ] && typefail="feat krever MINOR- (eller MAJOR-) bump — du gjorde en PATCH ($old → $new)"
      ;;
    fix|perf)
      [ "$kind" = minor ] && typefail="$prefix krever PATCH-bump — du gjorde en MINOR ($old → $new)"
      [ "$kind" = major ] && [ "$breaking" -ne 1 ] && typefail="$prefix krever PATCH-bump — MAJOR er kun for breaking endringer (merk med «!» eller «BREAKING CHANGE»)"
      ;;
  esac
  [ "$kind" = unknown ] && typefail="version øker ikke korrekt ($old → $new)"

  if [ -n "$typefail" ]; then
    printf '\n✗ Commit blokkert: feil bump-type.\n\n' >&2
    printf '  %s\n\n' "$typefail" >&2
    printf '  Reglene står i CLAUDE.md → "Versjonering / CHANGELOG":\n' >&2
    printf '    feat → npm version minor --no-git-tag-version\n' >&2
    printf '    fix/perf → npm version patch --no-git-tag-version\n\n' >&2
    exit 1
  fi
fi

exit 0
