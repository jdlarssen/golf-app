#!/usr/bin/env bash
# Pre-push-gate for Tørny. BLOKKERENDE — speiler CI-ens `verify`-jobb.
#
# Kjører de samme tre sjekkene som .github/workflows/ci.yml blokkerer på, FØR
# koden forlater maskinen:
#   1. typecheck (tsc --noEmit) — fanger schema-drift mot Supabase-typene.
#      Dette er rotårsaken bak prod-havariene (#641/#642/#647/#648, helse-
#      auditen 2026-06-17): en kolonne som ikke fantes kompilerte grønt og
#      feilet først i prod. Med <Database>-typen koblet inn (#672) blir det en
#      rød strek her i stedet for en 500-side hos en bruker.
#   2. lint (eslint) — fanger stil-/lenke-/hook-regresjoner. Feiler kun på
#      errors; warnings blokkerer ikke (lagt til i #692 da de 22 gamle feilene
#      ble ryddet).
#   3. test (vitest run) — fanger logikk-regresjoner.
#
# Hvorfor lokalt: ekte branch protection er paywallet på private gratis-repo
# (GitHub krever Pro eller offentlig repo). Dette er den gratis erstatningen
# som hindrer at rød kode i det hele tatt når en PR. CI kjører de samme tre på
# PR-en som synlig backstop ved merge.
#
# Bevisst UTELATT: e2e (trenger live-env + er treg — kjøres kun i CI via RUN_E2E).
#
# Nød-utvei finnes (git push --no-verify), men CLAUDE.md forbyr den. Den hører
# til ekte nødssituasjoner, ikke til å slippe unna en rød gate.

# pre-push får <remote-navn> <remote-url> som argumenter; gaten gjelder uansett
# hvilken remote/branch du pusher, fordi hver branch blir en PR der CI kjører.

# ── Vakt: aldri direkte push til main (CLAUDE.md → "Branch + PR-flyt"). ──
# Etter v1.0.0 går alt arbeid via PR. Git gir oss linjer på stdin på formen
# "<local-ref> <local-sha> <remote-ref> <remote-sha>" — vi blokkerer hvis noen
# av dem peker på refs/heads/main. Ekte vedlikeholds-unntak: kjør pushen med
# ALLOW_MAIN_PUSH=1 foran. Kjøres FØRST (billigst, og skal blokkere uansett
# node_modules-status).
if [ "${ALLOW_MAIN_PUSH:-0}" != "1" ]; then
  while read -r _localref _localsha remoteref _remotesha; do
    case "$remoteref" in
      refs/heads/main)
        printf '\n✗ Push blokkert: direkte push til main er ikke tillatt.\n' >&2
        printf '  Alt arbeid går via PR (CLAUDE.md → "Branch + PR-flyt"):\n' >&2
        printf '    git push origin <branch>\n' >&2
        printf '    gh pr create --base main --title "…" --body "Closes #N\\n\\n…"\n' >&2
        printf '  Ekte vedlikeholds-unntak: ALLOW_MAIN_PUSH=1 git push …\n\n' >&2
        exit 1
        ;;
    esac
  done
fi

# Uten avhengigheter kan vi ikke kjøre gaten. Bedre å slippe pushen gjennom enn
# å brikke et friskt klon før `npm install` — du har uansett ikke kunnet bygge
# eller teste uten dem.
if [ ! -d node_modules ]; then
  printf '⚠️  pre-push: node_modules mangler — hopper over gaten. Kjør `npm install`.\n' >&2
  exit 0
fi

run_gate() {
  label="$1"; shift
  printf '▶ pre-push: %s …\n' "$label" >&2
  if ! "$@"; then
    printf '\n✗ Push blokkert: «%s» feilet.\n' "$label" >&2
    printf '  Fiks rødt før du pusher. Dette er den samme porten CI kjører på PR-en,\n' >&2
    printf '  bare flyttet hit så feilen aldri rekker fram til main.\n' >&2
    printf '  (Nød-utvei `git push --no-verify` finnes, men CLAUDE.md forbyr den.)\n\n' >&2
    exit 1
  fi
}

# typecheck først: billigst signal, og det er schema-drift-vakta — rotårsaken.
# lint deretter: også raskt, så stil-/lenke-feil faller før den trege test-runden.
run_gate "typecheck (schema-drift-vakt)" npm run typecheck
run_gate "lint (eslint)" npm run lint
run_gate "test (vitest)" npm test

printf '✓ pre-push-gate grønn — typecheck + lint + test passerte.\n' >&2
exit 0
