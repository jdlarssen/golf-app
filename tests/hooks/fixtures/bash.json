[
  {
    "name": "no-verify ekte commit-flagg → deny",
    "expect": "deny",
    "payload": { "tool_input": { "command": "git commit --no-verify -m \"fix: x\"" } }
  },
  {
    "name": "regresjon defekt a: --no-verify kun nevnt i quotet body → pr-create-remind, IKKE deny",
    "expect": "context",
    "payload": { "tool_input": { "command": "gh pr create --title \"t\" --body \"Closes #5 — merk: aldri bruk --no-verify her\"" } }
  },
  {
    "name": "regresjon defekt a: --no-verify i FLERLINJET quotet commit-body → none",
    "expect": "none",
    "payload": { "tool_input": { "command": "git commit -m \"chore: docs\n\nforklarer hvorfor --no-verify er forbudt\nog hva gatene fanger\n\nRefs #1074\"" } }
  },
  {
    "name": "gh pr merge --squash → deny",
    "expect": "deny",
    "payload": { "tool_input": { "command": "gh pr merge 5 --squash --delete-branch" } }
  },
  {
    "name": "git push --force → ask",
    "expect": "ask",
    "payload": { "tool_input": { "command": "git push --force origin claude/x" } }
  },
  {
    "name": "git push --force-with-lease → none (rebase-flyten)",
    "expect": "none",
    "payload": { "tool_input": { "command": "git push --force-with-lease origin claude/x" } }
  },
  {
    "name": "regresjon defekt b: sammensatt kommando før gh pr create → context",
    "expect": "context",
    "payload": { "tool_input": { "command": "cd /tmp/x && gh pr create --title \"t\" --body \"Closes #5\"" } }
  },
  {
    "name": "gh issue create uten milestone → context",
    "expect": "context",
    "payload": { "tool_input": { "command": "gh issue create --title \"x\" --body \"y\"" } }
  },
  {
    "name": "gh issue create med milestone → none",
    "expect": "none",
    "payload": { "tool_input": { "command": "gh issue create --title \"x\" --body \"y\" --milestone \"Backlog\"" } }
  },
  {
