{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/bash-guard.sh\"",
            "statusMessage": "Sjekker kommando mot Tørny-reglene"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/eslint-fix.sh\"",
            "statusMessage": "eslint --fix (endret fil)"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "forge@floka-marketplace": true,
    "humanizer@floka-marketplace": true,
    "no-nb@floka-marketplace": true
  },
  "extraKnownMarketplaces": {
    "floka-marketplace": {
      "source": {
        "source": "github",
        "repo": "Floka-as/floka-marketplace"
      }
    }
  }
}
